# Database
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@db:5432/appdb

# For Alembic (sync driver)
DATABASE_URL_SYNC=postgresql+psycopg2://appuser:apppassword@db:5432/appdb

# Application
APP_NAME="My App API"
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres (used by docker-compose)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb